    <text x="900" y="42" text-anchor="middle" fill="#10b981" font-size="9" font-weight="bold">20 ns Period</text>
    <text x="900" y="56" text-anchor="middle" fill="#064e3b" font-size="7">50 MHz Scan Rate</text>

    <!-- Arrows top row -->
    <line x1="170" y1="45" x2="208" y2="45" stroke="#00d4ff" stroke-width="1.5" marker-end="url(#arrow)" opacity=".7"/>
    <line x1="350" y1="45" x2="388" y2="45" stroke="#00d4ff" stroke-width="1.5" marker-end="url(#arrow)" opacity=".7"/>
    <line x1="600" y1="45" x2="638" y2="45" stroke="#f59e0b" stroke-width="1.2" marker-end="url(#arrow)" opacity=".6"/>

    <!-- EDT → down arrow -->
    <line x1="490" y1="80" x2="490" y2="108" stroke="#7c3aed" stroke-width="1.5" marker-end="url(#arrow2)" opacity=".8"/>

    <!-- ═══ Scan Chain Blocks ═══
         Row 1: ch1–ch8  (y=120)
