      {"ch":21,"ff":234,"sin":"SPI2_IO2_WP","sout":"GPO0"},
      {"ch":22,"ff":234,"sin":"SPI2_IO3_RST","sout":"GPO1"},
      {"ch":23,"ff":234,"sin":"SPI3_SCLK","sout":"GPO2","phy":true}
    ]
