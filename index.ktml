      {"ch":7,"ff":234,"sin":"ETH_MDCLK","sout":"CAN1_RX"},
      {"ch":8,"ff":234,"sin":"SPI0_SCLK","sout":"CAN1_TX"},
      {"ch":9,"ff":234,"sin":"SPI0_SCSN","sout":"UART2_TX"},
      {"ch":10,"ff":234,"sin":"SPI0_IO0_SDO","sout":"UART3_TX"},
      {"ch":11,"ff":234,"sin":"SPI0_IO1_SDI","sout":"GPIO0"},
      {"ch":12,"ff":234,"sin":"SPI0_IO2_WP","sout":"GPIO1"},
      {"ch":13,"ff":234,"sin":"SPI0_IO3_RST","sout":"GPIO2"},
