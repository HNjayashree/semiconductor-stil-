          <span style="color:var(--accent)">ch1 – ch22 (22 chains)</span>
        </div>
        <div style="display:flex;align-items:center;gap.5rem;font-size:.75rem;font-family:var(--font-mono)">
          <span style="color:var(--muted);width:140px">PHY EDT Channels</span>
          <div class="ch-len"><div class="ch-len-fill" style="width:4.4%;background:linear-gradient(90deg,#5b21b6,#c4b5fd)"></div></div>
          <span style="color:#c4b5fd">ch1 – phy (1 chain)</span>
        </div>
      </div>
