<!-- ══════════════════════════════════════════════════════
     TAB: FAULT SIMULATOR
═══════════════════════════════════════════════════════════ -->
<div id="tab-fault" class="tab-panel">
  <div class="section-label">Stuck-At Fault Injection Simulator</div>

  <div class="fault-grid">
    <div>
      <div class="card fault-controls">
        <div>
          <div class="ctrl-label">Target Scan Chain</div>
          <select id="sim-chain">
            <option value="all">ALL Chains (Broadcast)</option>
            <option value="1">CH 01 — ETH_TXCLK → ETH_RXD3</option>
            <option value="2">CH 02 — ETH_TXD0 → ETH_RXCTL</option>
            <option value="3">CH 03 — ETH_TXD1 → ETH_MDIO</option>
            <option value="4">CH 04 — ETH_TXD2 → CAN0_RX</option>
            <option value="5">CH 05 — ETH_TXD3 → CAN0_TX</option>
            <option value="6">CH 06 — ETH_TXCTL → CAN0_STBY</option>
            <option value="7">CH 07 — ETH_MDCLK → CAN1_RX</option>
            <option value="8">CH 08 — SPI0_SCLK → CAN1_TX</option>
            <option value="9">CH 09 — SPI0_SCSN → UART2_TX</option>
            <option value="10">CH 10 — SPI0_IO0_SDO → UART3_TX</option>
            <option value="11">CH 11 — SPI0_IO1_SDI → GPIO0</option>
            <option value="12">CH 12 — SPI0_IO2_WP → GPIO1</option>
            <option value="13">CH 13 — SPI0_IO3_RST → GPIO2</option>
            <option value="14">CH 14 — SPI1_SCSN → GPIO3</option>
            <option value="15">CH 15 — SPI1_SDO → GPIO4</option>
            <option value="16">CH 16 — SPI1_SDI → GPIO5</option>
            <option value="17">CH 17 — SPI2_SCLK → GPIO6</option>
            <option value="18">CH 18 — SPI2_SCSN → GPIO7</option>
            <option value="19">CH 19 — SPI2_IO0_SDO → GPIO8</option>
            <option value="20">CH 20 — SPI2_IO1_SDI → NETCLK</option>
            <option value="21">CH 21 — SPI2_IO2_WP → GPO0</option>
            <option value="22">CH 22 — SPI2_IO3_RST → GPO1</option>
            <option value="23">CH 23 (PHY) — SPI3_SCLK → GPO2</option>
          </select>
        </div>
        <div>
          <div class="ctrl-label">Fault Type</div>
          <select id="sim-fault">
            <option value="sa0">Stuck-At-0 (SA0)</option>
            <option value="sa1">Stuck-At-1 (SA1)</option>
            <option value="both">Both SA0 + SA1</option>
            <option value="random">Random Fault Injection</option>
          </select>
        </div>
        <div>
          <div class="ctrl-label">Fault Position (FF index in chain: 0–233)</div>
          <input type="number" id="sim-pos" min="0" max="233" value="42" style="margin-bottom:.5rem"/>
          <input type="range" id="sim-pos-range" min="0" max="233" value="42"/>
        </div>
        <div>
          <div class="ctrl-label">Pattern Range</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
            <input type="number" id="sim-pat-start" min="0" max="29624" value="0" placeholder="Start"/>
            <input type="number" id="sim-pat-end" min="0" max="29624" value="29624" placeholder="End"/>
          </div>
        </div>
        <div>
          <div class="ctrl-label">Simulation Speed</div>
          <select id="sim-speed">
            <option value="fast">Fast (batch)</option>
            <option value="normal" selected>Normal (animated)</option>
            <option value="slow">Slow (step-by-step)</option>
          </select>
        </div>
        <button class="run-btn" onclick="runFaultSim()">⚡ Run Fault Simulation</button>
        <button class="run-btn" style="background:rgba(239,68,68,.2);border:1px solid #ef4444;box-shadow:none;color:#ef4444" onclick="clearLog()">✕ Clear Log</button>
      </div>
    </div>

    <div>
      <div class="card" style="padding:0;overflow:hidden;height:100%">
        <div style="padding:.75rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
          <span style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)">Tester Fail Log Output</span>
          <span style="display:flex;align-items:center;gap:.4rem;font-size:.7rem;font-family:var(--font-mono);color:var(--ok)">
            <span class="ping"></span> <span id="log-status">Ready</span>
          </span>
        </div>
        <div class="fault-log" id="fault-log">
          <span class="log-info">// STIL Fault Injection Simulator — MY_DES EDT Scan</span><br>
          <span class="log-dim">// Source: Production_SCAN_stuck_at_Example_3.stil</span><br>
          <span class="log-dim">// Chains: 23 × 234 FF | Clock: ETH_RXCLK | Test: EDT_SCAN_TEST</span><br>
          <span class="log-dim">// Configure parameters and click Run Fault Simulation...</span><br>
        </div>
      </div>
    </div>
  </div>

  <div class="spacer"></div>
  <div class="section-label">Fault Statistics</div>
  <div class="stats-grid" id="fault-stats">
    <div class="card"><div class="card-title">Faults Injected</div><div class="card-value" id="stat-injected">—</div></div>
    <div class="card"><div class="card-title">Faults Detected</div><div class="card-value" id="stat-detected" style="color:var(--ok)">—</div></div>
    <div class="card"><div class="card-title">Faults Missed</div><div class="card-value" id="stat-missed" style="color:var(--err)">—</div></div>
    <div class="card"><div class="card-title">Fault Coverage</div><div class="card-value" id="stat-coverage" style="color:var(--accent)">—</div></div>
    <div class="card"><div class="card-title">ATPG Patterns Used</div><div class="card-value" id="stat-patterns">—</div></div>
    <div class="card"><div class="card-title">Simulation Time</div><div class="card-value" id="stat-time">—</div></div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     TAB: HEATMAP
═══════════════════════════════════════════════════════════ -->
<div id="tab-heatmap" class="tab-panel">
  <div class="section-label">Fault Distribution Heatmap — 23 Chains × 234 FF</div>
  <div class="two-col" style="margin-bottom:1.5rem">
    <div class="card">
      <div class="card-title">Heatmap Mode</div>
      <div style="display:flex;gap:.5rem;margin-top:.5rem;flex-wrap:wrap">
        <button class="nav-pill active" id="hm-random" onclick="drawHeatmap('random',this)">Random Fault</button>
        <button class="nav-pill" id="hm-sa0" onclick="drawHeatmap('sa0',this)">Stuck-At-0 Bias</button>
        <button class="nav-pill" id="hm-sa1" onclick="drawHeatmap('sa1',this)">Stuck-At-1 Bias</button>
        <button class="nav-pill" id="hm-center" onclick="drawHeatmap('center',this)">Center-Chain Bias</button>
        <button class="nav-pill" id="hm-edge" onclick="drawHeatmap('edge',this)">Edge-FF Bias</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Heatmap Legend</div>
      <div class="heatmap-legend">
        <span>Low Fault Density</span>
        <div class="legend-bar"></div>
        <span>High Fault Density</span>
      </div>
      <div style="margin-top:.75rem;font-size:.7rem;color:var(--muted);font-family:var(--font-mono);line-height:1.8">
        X-axis: FF position (0–233) · Y-axis: Scan Chain (CH01–CH23)
      </div>
    </div>
  </div>
  <div class="card" style="padding:1rem">
    <canvas id="heatmap-canvas" width="1000" height="350"></canvas>
  </div>
</div>

</main>

<script>
/* ═══════════════════════════════════════════════
   DATA
═══════════════════════════════════════════════ */
const chains = [
  {ch:1, ff:234, sin:"ETH_TXCLK",    sout:"ETH_RXD3",   phy:false},
  {ch:2, ff:234, sin:"ETH_TXD0",     sout:"ETH_RXCTL",  phy:false},
  {ch:3, ff:234, sin:"ETH_TXD1",     sout:"ETH_MDIO",   phy:false},
  {ch:4, ff:234, sin:"ETH_TXD2",     sout:"CAN0_RX",    phy:false},
  {ch:5, ff:234, sin:"ETH_TXD3",     sout:"CAN0_TX",    phy:false},
  {ch:6, ff:234, sin:"ETH_TXCTL",    sout:"CAN0_STBY",  phy:false},
  {ch:7, ff:234, sin:"ETH_MDCLK",    sout:"CAN1_RX",    phy:false},
  {ch:8, ff:234, sin:"SPI0_SCLK",    sout:"CAN1_TX",    phy:false},
  {ch:9, ff:234, sin:"SPI0_SCSN",    sout:"UART2_TX",   phy:false},
  {ch:10,ff:234, sin:"SPI0_IO0_SDO", sout:"UART3_TX",   phy:false},
  {ch:11,ff:234, sin:"SPI0_IO1_SDI", sout:"GPIO0",      phy:false},
  {ch:12,ff:234, sin:"SPI0_IO2_WP",  sout:"GPIO1",      phy:false},
  {ch:13,ff:234, sin:"SPI0_IO3_RST", sout:"GPIO2",      phy:false},
  {ch:14,ff:234, sin:"SPI1_SCSN",    sout:"GPIO3",      phy:false},
  {ch:15,ff:234, sin:"SPI1_SDO",     sout:"GPIO4",      phy:false},
  {ch:16,ff:234, sin:"SPI1_SDI",     sout:"GPIO5",      phy:false},
  {ch:17,ff:234, sin:"SPI2_SCLK",    sout:"GPIO6",      phy:false},
  {ch:18,ff:234, sin:"SPI2_SCSN",    sout:"GPIO7",      phy:false},
  {ch:19,ff:234, sin:"SPI2_IO0_SDO", sout:"GPIO8",      phy:false},
  {ch:20,ff:234, sin:"SPI2_IO1_SDI", sout:"NETCLK",     phy:false},
  {ch:21,ff:234, sin:"SPI2_IO2_WP",  sout:"GPO0",       phy:false},
  {ch:22,ff:234, sin:"SPI2_IO3_RST", sout:"GPO1",       phy:false},
  {ch:23,ff:234, sin:"SPI3_SCLK",    sout:"GPO2",       phy:true},
];

/* ── Tab switching ── */
function showTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-pill').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  event.target.classList.add('active');
  if(name==='heatmap') setTimeout(()=>drawHeatmap('random',document.getElementById('hm-random')),50);
}

/* ══════════════════════════════════════════════
   BUILD CHAIN TABLE
════════════════════════════════════════════════ */
(function buildChainTable(){
  const tbody = document.getElementById('chain-tbody');
  chains.forEach(c=>{
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td class="ch-num">CH ${String(c.ch).padStart(2,'0')}</td>
      <td style="color:var(--muted);font-size:.68rem">${c.phy?'phy_inst':'core_inst'} · edt_block_channel${c.ch}</td>
      <td>
        <div class="ch-len"><div class="ch-len-fill" style="width:100%"></div></div>
        <span style="color:var(--text)">${c.ff} FF</span>
      </td>
      <td class="ch-in">${c.sin}</td>
      <td class="ch-out">${c.sout}</td>
      <td style="color:var(--warn)">ETH_RXCLK</td>
      <td style="color:var(--ok)">0 (none)</td>
      <td><span class="stat-badge ${c.phy?'badge-warn':'badge-info'}" style="font-size:.65rem">${c.phy?'PHY':'CORE'}</span></td>`;
    tbody.appendChild(tr);
  });
})();

/* ══════════════════════════════════════════════
   BUILD ARCH SVG CHAIN BLOCKS
════════════════════════════════════════════════ */
(function buildArchBlocks(){
  const g = document.getElementById('chain-blocks');
  const COLS=8, ROW_Y=[120,270,420], W=115, H=85, GAP=10, startX=30;
  chains.forEach((c,i)=>{
    const col=i%COLS, row=Math.floor(i/COLS);
    const x=startX+col*(W+GAP), y=ROW_Y[row]||560;
    const isLast=col===COLS-1||i===chains.length-1;
    const fill=c.phy?'rgba(91,33,182,.35)':'rgba(30,64,175,.35)';
    const stroke=c.phy?'#7c3aed':'#1d4ed8';

    // vertical arrow from EDT
    if(i<COLS){ // row 0
      const arrowX=x+W/2;
      const el=document.createElementNS('http://www.w3.org/2000/svg','line');
      el.setAttribute('x1',490); el.setAttribute('y1',108);
      el.setAttribute('x2',arrowX); el.setAttribute('y2',y-2);
      el.setAttribute('stroke','#7c3aed'); el.setAttribute('stroke-width','0.8');
      el.setAttribute('stroke-dasharray','4 3'); el.setAttribute('opacity','0.4');
      g.appendChild(el);
    }

    // block
    const rect=document.createElementNS('http://www.w3.org/2000/svg','rect');
    Object.entries({x,y,width:W,height:H,rx:6,fill,stroke,'stroke-width':1}).forEach(([k,v])=>rect.setAttribute(k,v));
    g.appendChild(rect);

    const addText=(txt,dy,col2,size,weight)=>{
      const t=document.createElementNS('http://www.w3.org/2000/svg','text');
      t.setAttribute('x',x+W/2); t.setAttribute('y',y+dy);
      t.setAttribute('text-anchor','middle');
      t.setAttribute('fill',col2); t.setAttribute('font-size',size||8);
      if(weight) t.setAttribute('font-weight',weight);
      t.textContent=txt; g.appendChild(t);
    };
    addText(`CH ${String(c.ch).padStart(2,'0')}`,18,'#93c5fd',9,'bold');
    addText(`${c.ff} FFs`,30,'#60a5fa',8);
    addText(`IN: ${c.sin}`,44,'rgba(16,185,129,.8)',7);
    addText(`OUT: ${c.sout}`,56,'rgba(245,158,11,.8)',7);
    addText(c.phy?'[PHY]':'[CORE]',70,'rgba(100,116,139,.7)',7);
  });
})();

/* ══════════════════════════════════════════════
   FAULT SIMULATOR
════════════════════════════════════════════════ */
// sync range & number
document.getElementById('sim-pos-range').oninput=e=>{document.getElementById('sim-pos').value=e.target.value};
document.getElementById('sim-pos').oninput=e=>{document.getElementById('sim-pos-range').value=e.target.value};

function log(msg,cls='log-dim'){
  const el=document.getElementById('fault-log');
  el.innerHTML+=`<span class="${cls}">${msg}</span><br>`;
  el.scrollTop=el.scrollHeight;
}
function clearLog(){
  document.getElementById('fault-log').innerHTML='';
  ['injected','detected','missed','coverage','patterns','time'].forEach(id=>{
    document.getElementById('stat-'+id).textContent='—';
  });
}

async function runFaultSim(){
  const chainSel=document.getElementById('sim-chain').value;
  const faultType=document.getElementById('sim-fault').value;
  const pos=parseInt(document.getElementById('sim-pos').value);
  const patStart=parseInt(document.getElementById('sim-pat-start').value);
  const patEnd=parseInt(document.getElementById('sim-pat-end').value);
  const speed=document.getElementById('sim-speed').value;
  const delay=speed==='slow'?300:speed==='normal'?60:5;

  document.getElementById('log-status').textContent='Running...';
  const t0=Date.now();

  log('');
  log(`════════════════════════════════════════════════════`,'log-info');
  log(`  FAULT INJECTION SIMULATION — MY_DES EDT Scan`,'log-info');
  log(`════════════════════════════════════════════════════`,'log-info');

  const targetChains=chainSel==='all'?chains:chains.filter(c=>c.ch===parseInt(chainSel));
  const types=faultType==='both'?['SA0','SA1']:faultType==='random'?[Math.random()>.5?'SA0':'SA1']:[faultType.toUpperCase()];
  const patCount=patEnd-patStart+1;

  let injected=0, detected=0, missed=0;

  log(`[INIT] Target: ${chainSel==='all'?'ALL 23 chains':'CH '+chainSel}`,'log-dim');
  log(`[INIT] Fault type: ${types.join('+')} | FF position: ${pos}`,'log-dim');
  log(`[INIT] Pattern range: ${patStart} → ${patEnd} (${patCount} patterns)`,'log-dim');
  log(`[INIT] Clock: ETH_RXCLK | Period: 20ns`,'log-dim');
  log(``);

  for(const chain of targetChains){
    await new Promise(r=>setTimeout(r,delay));
    log(`[SCAN] CH ${String(chain.ch).padStart(2,'0')} | ${chain.sin} → ${chain.sout} | ${chain.ff} FF`,'log-info');

    for(const ft of types){
      injected++;
      await new Promise(r=>setTimeout(r,delay/2));

      // Simulate detection based on position and type
      const detectionProb = ft==='SA0'
        ? (pos<100?0.95:pos<180?0.88:0.72)
        : (pos<50?0.92:pos<150?0.91:0.78);
      const isDetected = Math.random()<detectionProb;
      const ffName = `FF[${pos}]@${chain.sin}`;

      if(isDetected){
        detected++;
        const patHit=patStart+Math.floor(Math.random()*patCount);
        log(`  [DETECT] ${ft} @ ${ffName} → FAIL at Pattern ${patHit} | SCAN_OUT mismatch on ${chain.sout}`,'log-ok');
      } else {
        missed++;
        log(`  [ESCAPE] ${ft} @ ${ffName} → NOT DETECTED in ${patCount} patterns`,'log-err');
      }
    }
  }

  const elapsed=Date.now()-t0;
  const coverage=((detected/injected)*100).toFixed(2);

  log(``);
  log(`════════════════════════════════════════════════════`,'log-info');
  log(`  SIMULATION COMPLETE`,'log-info');
  log(`  Injected: ${injected} | Detected: ${detected} | Missed: ${missed}`,'log-warn');
  log(`  Fault Coverage: ${coverage}%`,'log-ok');
  log(`════════════════════════════════════════════════════`,'log-info');

  document.getElementById('stat-injected').textContent=injected;
  document.getElementById('stat-detected').textContent=detected;
  document.getElementById('stat-missed').textContent=missed;
  document.getElementById('stat-coverage').textContent=coverage+'%';
  document.getElementById('stat-patterns').textContent=patCount.toLocaleString();
  document.getElementById('stat-time').textContent=(elapsed/1000).toFixed(2)+'s';
  document.getElementById('log-status').textContent='Done';
}

/* ══════════════════════════════════════════════
   HEATMAP
════════════════════════════════════════════════ */
function drawHeatmap(mode, btn){
  document.querySelectorAll('#tab-heatmap .nav-pill').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');

  const canvas=document.getElementById('heatmap-canvas');
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const nChains=23, nFF=234;
  const cellW=W/nFF, cellH=(H-40)/nChains;
  const PAD_LEFT=50, PAD_TOP=30;

  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#070b14'; ctx.fillRect(0,0,W,H);

  // axis labels
  ctx.fillStyle='#64748b'; ctx.font='10px Space Mono';
  ctx.fillText('FF Index →',PAD_LEFT,15);
  for(let i=0;i<nFF;i+=40){
    ctx.fillStyle='#475569'; ctx.font='8px Space Mono';
    ctx.fillText(i, PAD_LEFT+i*((W-PAD_LEFT)/nFF), PAD_TOP-4);
  }

  for(let cy=0;cy<nChains;cy++){
    // chain label
    ctx.fillStyle='#475569'; ctx.font='8px Space Mono';
    ctx.fillText(`CH${String(cy+1).padStart(2,'0')}`, 2, PAD_TOP+cy*cellH+cellH/2+3);

    for(let fx=0;fx<nFF;fx++){
      let intensity=0;
      if(mode==='random') intensity=Math.random();
      else if(mode==='sa0') intensity=Math.random()*(fx<117?1:.4);
      else if(mode==='sa1') intensity=Math.random()*(fx>=117?1:.4);
      else if(mode==='center') {
        const distCenter=Math.abs(cy-11)/11;
        intensity=Math.random()*(1-distCenter*.6);
      } else if(mode==='edge') {
        const distEdge=Math.min(cy,22-cy)/11;
        intensity=Math.random()*(1-distEdge*.7)+distEdge*.3;
      }

      // color map: dark blue → purple → red → amber
      let r,g,b;
      if(intensity<.25){r=Math.floor(intensity*4*60);g=0;b=Math.floor(60+intensity*4*120);}
      else if(intensity<.5){const t=(intensity-.25)*4;r=Math.floor(60+t*120);g=0;b=Math.floor(180-t*80);}
      else if(intensity<.75){const t=(intensity-.5)*4;r=Math.floor(180+t*75);g=Math.floor(t*30);b=Math.floor(100-t*100);}
      else{const t=(intensity-.75)*4;r=240;g=Math.floor(30+t*129);b=Math.floor(t*11);}

      ctx.fillStyle=`rgb(${r},${g},${b})`;
      ctx.fillRect(PAD_LEFT+fx*((W-PAD_LEFT)/nFF), PAD_TOP+cy*cellH, Math.max(1,(W-PAD_LEFT)/nFF-.5), cellH-.5);
    }
  }
}

// Initial render
window.addEventListener('load',()=>{
  // pre-render heatmap canvas size
  const canvas=document.getElementById('heatmap-canvas');
  canvas.width=1000; canvas.height=350;
});
</script>
</body>
</html>