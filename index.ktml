    <!-- Rows rendered by JS below -->
    <g id="chain-blocks"></g>

    <!-- Legend -->
    <g transform="translate(30,665)">
      <rect x="0" y="-8" width="12" height="12" rx="2" fill="#1e40af"/>
      <text x="16" y="2" fill="#64748b" font-size="8">Core EDT Channel</text>
      <rect x="120" y="-8" width="12" height="12" rx="2" fill="#5b21b6"/>
      <text x="136" y="2" fill="#64748b" font-size="8">PHY EDT Channel</text>
      <rect x="240" y="-8" width="12" height="12" rx="2" fill="rgba(16,185,129,.3)" stroke="rgba(16,185,129,.5)" stroke-width="1"/>
