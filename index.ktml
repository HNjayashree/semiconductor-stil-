<!-- ══════════════════════════════════════════════════════
     TAB: ARCHITECTURE DIAGRAM
═══════════════════════════════════════════════════════════ -->
<div id="tab-arch" class="tab-panel">
  <div class="section-label">Hardware Architecture Topology</div>
  <svg id="arch-diagram" viewBox="0 0 1100 700" xmlns="http://www.w3.org/2000/svg" font-family="'Space Mono',monospace">
    <defs>
      <linearGradient id="gAccent" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#7c3aed"/>
        <stop offset="100%" stop-color="#00d4ff"/>
      </linearGradient>
      <linearGradient id="gCard" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#111d33"/>
        <stop offset="100%" stop-color="#0d1525"/>
      </linearGradient>
      <filter id="glow">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#00d4ff" opacity=".7"/>
      </marker>
      <marker id="arrow2" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#7c3aed" opacity=".7"/>
      </marker>
    </defs>

    <!-- Background -->
    <rect width="1100" height="700" fill="#070b14"/>
    <!-- Grid -->
    <g stroke="#1e3055" stroke-width=".5" opacity=".4">
      <line x1="0" y1="80" x2="1100" y2="80"/>
      <line x1="0" y1="200" x2="1100" y2="200"/>
      <line x1="0" y1="320" x2="1100" y2="320"/>
      <line x1="0" y1="440" x2="1100" y2="440"/>
      <line x1="0" y1="560" x2="1100" y2="560"/>
      <line x1="0" y1="640" x2="1100" y2="640"/>
    </g>

    <!-- ── JTAG TAP Controller ── -->
    <rect x="30" y="20" width="140" height="50" rx="6" fill="url(#gCard)" stroke="#1e3055" stroke-width="1"/>
    <text x="100" y="40" text-anchor="middle" fill="#00d4ff" font-size="9" font-weight="bold">JTAG</text>
    <text x="100" y="55" text-anchor="middle" fill="#64748b" font-size="7">TDI·TDO·TMS·TCK·TRSTN</text>

    <!-- ── TAP Controller ── -->
    <rect x="210" y="20" width="140" height="50" rx="6" fill="url(#gCard)" stroke="#1e3055" stroke-width="1"/>
    <text x="280" y="40" text-anchor="middle" fill="#00d4ff" font-size="9" font-weight="bold">TAP CONTROLLER</text>
    <text x="280" y="55" text-anchor="middle" fill="#64748b" font-size="7">IEEE 1149.1 Compliant</text>

    <!-- ── EDT Engine ── -->
    <rect x="390" y="10" width="200" height="70" rx="8" fill="rgba(124,58,237,.15)" stroke="#7c3aed" stroke-width="1.5" filter="url(#glow)"/>
    <text x="490" y="33" text-anchor="middle" fill="#c4b5fd" font-size="10" font-weight="bold">EDT ENGINE</text>
    <text x="490" y="48" text-anchor="middle" fill="#7c3aed" font-size="8">Decompressor / Compactor</text>
    <text x="490" y="62" text-anchor="middle" fill="#64748b" font-size="7">Tessent EDT Core · edt_external=ON</text>

    <!-- ── Clock source ── -->
