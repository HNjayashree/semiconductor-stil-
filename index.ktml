  <!-- Full summary table -->
  <div class="section-label">Structured STIL Metadata</div>
  <div class="card" style="padding:0;overflow:hidden">
    <table class="summary-table">
      <thead><tr><th>Parameter</th><th>Value</th></tr></thead>
      <tbody>
        <tr><td>Design Title</td><td class="highlight">MY_TOP_MY_DES_stuck_with_init_stil_gz</td></tr>
