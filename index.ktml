         Row 3: ch17–ch23 (y=400) -->

    <!-- CHANNEL DATA -->
    <script type="application/json" id="chain-data">
    [
      {"ch":1,"ff":234,"sin":"ETH_TXCLK","sout":"ETH_RXD3"},
      {"ch":2,"ff":234,"sin":"ETH_TXD0","sout":"ETH_RXCTL"},
      {"ch":3,"ff":234,"sin":"ETH_TXD1","sout":"ETH_MDIO"},
