<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STIL Analyzer Pro — MY_DES Scan Diagnostics</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:       #070b14;
    --surface:  #0d1525;
    --card:     #111d33;
    --border:   #1e3055;
    --accent:   #00d4ff;
    --accent2:  #7c3aed;
    --accent3:  #f59e0b;
    --ok:       #10b981;
    --warn:     #f59e0b;
    --err:      #ef4444;
    --text:     #e2e8f0;
    --muted:    #64748b;
    --font-mono: 'Space Mono', monospace;
    --font-ui:   'Syne', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-ui);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Grid bg ── */
  body::before {
    content:'';
    position:fixed; inset:0; pointer-events:none;
    background-image:
      linear-gradient(rgba(0,212,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,.03) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index:0;
  }

  /* ── Nav ── */
  nav {
    position: sticky; top:0; z-index: 100;
    background: rgba(7,11,20,.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 56px;
  }
  .brand { display:flex; align-items:center; gap:.75rem; }
  .brand-icon {
    width:28px; height:28px; border-radius:6px;
    background: linear-gradient(135deg,var(--accent),var(--accent2));
    display:flex; align-items:center; justify-content:center; font-size:14px;
  }
  .brand-name { font-size:.9rem; font-weight:800; letter-spacing:.04em; color:var(--accent); }
  .brand-sub { font-size:.65rem; color:var(--muted); letter-spacing:.1em; text-transform:uppercase; margin-top:-2px; }
  .nav-pills { display:flex; gap:.5rem; }
  .nav-pill {
    padding:.35rem .9rem; border-radius:20px; font-size:.75rem; font-weight:700;
    letter-spacing:.06em; text-transform:uppercase; cursor:pointer;
    border: 1px solid var(--border); background:transparent; color:var(--muted);
    transition: all .2s;
  }
  .nav-pill:hover, .nav-pill.active { border-color:var(--accent); color:var(--accent); background:rgba(0,212,255,.07); }
  .exec-btn {
    padding:.4rem 1.1rem; border-radius:6px; font-size:.75rem; font-weight:700;
    letter-spacing:.06em; text-transform:uppercase; cursor:pointer;
    background: linear-gradient(135deg,var(--accent),var(--accent2));
    color:#fff; border:none; font-family:var(--font-ui);
    box-shadow: 0 0 16px rgba(0,212,255,.25);
    transition: box-shadow .2s;
  }
  .exec-btn:hover { box-shadow: 0 0 28px rgba(0,212,255,.45); }

  /* ── Tabs ── */
  .tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:2rem; }
  .tab {
    padding:.7rem 1.5rem; font-size:.8rem; font-weight:700;
    letter-spacing:.08em; text-transform:uppercase; cursor:pointer;
    color:var(--muted); border-bottom:2px solid transparent;
    transition: all .2s; background:transparent; border-top:none; border-left:none; border-right:none;
    font-family:var(--font-ui);
  }
  .tab:hover { color:var(--text); }
  .tab.active { color:var(--accent); border-bottom-color:var(--accent); }
  .tab-panel { display:none; animation: fadeIn .3s ease; }
  .tab-panel.active { display:block; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

  /* ── Layout ── */
  main { position:relative; z-index:1; padding:1.5rem 2rem 4rem; max-width:1600px; margin:auto; }
  .section-label {
    font-size:.65rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase;
    color:var(--accent); margin-bottom:1rem; display:flex; align-items:center; gap:.5rem;
  }
  .section-label::after { content:''; flex:1; height:1px; background:var(--border); }

  /* ── Cards ── */
  .card {
    background:var(--card); border:1px solid var(--border);
    border-radius:10px; padding:1.25rem 1.5rem;
    position:relative; overflow:hidden;
  }
  .card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:2px;
    background:linear-gradient(90deg,var(--accent2),var(--accent),transparent);
  }
  .card-title { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-bottom:.5rem; }
  .card-value { font-size:2rem; font-weight:800; color:var(--text); line-height:1; }
  .card-sub { font-size:.7rem; color:var(--muted); margin-top:.3rem; font-family:var(--font-mono); }

  .stat-badge {
    display:inline-flex; align-items:center; gap:.4rem;
    padding:.25rem .7rem; border-radius:20px;
    font-size:.7rem; font-weight:700; letter-spacing:.05em; font-family:var(--font-mono);
  }
  .badge-ok { background:rgba(16,185,129,.1); color:var(--ok); border:1px solid rgba(16,185,129,.25); }
  .badge-info { background:rgba(0,212,255,.1); color:var(--accent); border:1px solid rgba(0,212,255,.2); }
  .badge-warn { background:rgba(245,158,11,.1); color:var(--warn); border:1px solid rgba(245,158,11,.2); }

  /* ── Stats grid ── */
  .stats-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; margin-bottom:2rem; }

  /* ── Summary Table ── */
  .summary-table { width:100%; border-collapse:collapse; font-family:var(--font-mono); font-size:.8rem; }
  .summary-table th {
    text-align:left; padding:.6rem 1rem; font-size:.65rem; letter-spacing:.1em;
    text-transform:uppercase; color:var(--muted); border-bottom:1px solid var(--border);
    background:rgba(0,0,0,.2);
  }
  .summary-table td { padding:.7rem 1rem; border-bottom:1px solid rgba(255,255,255,.04); }
  .summary-table tr:hover td { background:rgba(0,212,255,.03); }
  .summary-table td:first-child { color:var(--muted); font-size:.75rem; }
  .summary-table td:last-child { color:var(--text); font-weight:700; }
  .highlight { color:var(--accent) !important; }

  /* ── Chain Table ── */
  .chain-table { width:100%; border-collapse:collapse; font-family:var(--font-mono); font-size:.75rem; }
  .chain-table th {
    padding:.5rem .75rem; font-size:.6rem; letter-spacing:.1em; text-transform:uppercase;
    color:var(--muted); border-bottom:1px solid var(--border); background:rgba(0,0,0,.25); text-align:left;
  }
  .chain-table td { padding:.55rem .75rem; border-bottom:1px solid rgba(255,255,255,.04); }
  .chain-table tr:hover td { background:rgba(0,212,255,.04); cursor:pointer; }
  .ch-num { color:var(--accent); font-weight:700; }
  .ch-len {
    display:inline-block; width:120px; height:8px; border-radius:4px;
    background:var(--border); position:relative; overflow:hidden; vertical-align:middle; margin-right:.5rem;
  }
  .ch-len-fill {
    position:absolute; left:0; top:0; height:100%; border-radius:4px;
    background:linear-gradient(90deg,var(--accent2),var(--accent));
  }
  .ch-in { color:var(--ok); }
  .ch-out { color:var(--warn); }

  /* ── Architecture Diagram SVG ── */
  #arch-diagram { width:100%; border-radius:10px; border:1px solid var(--border); overflow:hidden; background:var(--surface); }

  /* ── Fault Simulator ── */
  .fault-grid { display:grid; grid-template-columns: 1fr 1fr; gap:1.5rem; }
  .fault-controls { display:flex; flex-direction:column; gap:1rem; }
  .ctrl-label { font-size:.7rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:.35rem; }
  select, input[type=number], input[type=range] {
    width:100%; background:var(--surface); border:1px solid var(--border);
    color:var(--text); padding:.5rem .75rem; border-radius:6px;
    font-family:var(--font-mono); font-size:.8rem; outline:none;
    transition:border-color .2s;
  }
  select:focus, input:focus { border-color:var(--accent); }
  .run-btn {
    padding:.65rem 1.2rem; border-radius:6px; border:none;
    background:linear-gradient(135deg,var(--accent2),var(--accent));
    color:#fff; font-family:var(--font-ui); font-weight:700; font-size:.8rem;
    letter-spacing:.06em; text-transform:uppercase; cursor:pointer;
    box-shadow:0 0 20px rgba(124,58,237,.3); transition:box-shadow .2s;
  }
  .run-btn:hover { box-shadow:0 0 32px rgba(0,212,255,.4); }

  /* ── Fault log ── */
  .fault-log {
    background:rgba(0,0,0,.4); border:1px solid var(--border); border-radius:8px;
    padding:1rem; font-family:var(--font-mono); font-size:.72rem;
    height:340px; overflow-y:auto; line-height:1.8;
  }
  .fault-log::-webkit-scrollbar { width:4px; }
  .fault-log::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
  .log-ok { color:var(--ok); }
  .log-err { color:var(--err); }
  .log-warn { color:var(--warn); }
  .log-info { color:var(--accent); }
  .log-dim { color:var(--muted); }

  /* ── Heatmap ── */
  #heatmap-canvas { width:100%; border-radius:8px; border:1px solid var(--border); }
  .heatmap-legend { display:flex; align-items:center; gap:1rem; margin-top:.75rem; font-family:var(--font-mono); font-size:.7rem; color:var(--muted); }
  .legend-bar {
    flex:1; height:12px; border-radius:4px;
    background:linear-gradient(90deg,#1a1a2e,#7c3aed,#ef4444,#f59e0b);
  }

  /* ── Progress ring ── */
  .ring-wrap { display:flex; flex-direction:column; align-items:center; gap:.5rem; }
  .ring-label { font-size:.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }
  .ring-val { font-size:1.4rem; font-weight:800; color:var(--accent); font-family:var(--font-mono); }

  /* ── Two-col layout ── */
  .two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  .three-col { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }

  /* ── Glow ping ── */
  .ping {
    display:inline-block; width:8px; height:8px; border-radius:50%;
    background:var(--ok); box-shadow:0 0 8px var(--ok);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.85)} }

  .spacer { height:1.5rem; }

  /* scrollable chain list */
  .chain-scroll { max-height:460px; overflow-y:auto; border-radius:8px; }
  .chain-scroll::-webkit-scrollbar { width:4px; }
  .chain-scroll::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }

  /* Responsive */
  @media(max-width:900px) {
    .two-col,.three-col,.fault-grid { grid-template-columns:1fr; }
    .stats-grid { grid-template-columns:repeat(2,1fr); }
  }
</style>
</head>
<body>

<nav>
  <div class="brand">
    <div class="brand-icon">⬡</div>
    <div>
      <div class="brand-name">STIL ANALYZER PRO</div>
      <div class="brand-sub">Enterprise Scan Diagnostics</div>
    </div>
  </div>
  <div class="nav-pills">
    <button class="nav-pill active" onclick="showTab('summary')">Summary</button>
    <button class="nav-pill" onclick="showTab('arch')">Architecture</button>
    <button class="nav-pill" onclick="showTab('chains')">Chains</button>
    <button class="nav-pill" onclick="showTab('fault')">Fault Sim</button>
    <button class="nav-pill" onclick="showTab('heatmap')">Heatmap</button>
  </div>
  <button class="exec-btn">⚡ Execute Pipeline</button>
</nav>

<main>

<!-- ══════════════════════════════════════════════════════
     TAB: SUMMARY
═══════════════════════════════════════════════════════════ -->
<div id="tab-summary" class="tab-panel active">
